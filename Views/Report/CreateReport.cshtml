@model MITCRMS.Models.DTOs.Report.CreateReportRequestModel

@{
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
    ViewData["Title"] = "Create Report";
}

<section class="staff-page-header">
    <div>
        <h1 class="staff-page-title">Submit New Report</h1>
        <p class="staff-page-subtitle">
            Complete the form below to document your department's academic, operational, or technical activity with the right level of institutional clarity.
        </p>
    </div>
</section>

<form asp-action="CreateReport" method="post" enctype="multipart/form-data" id="reportForm">
    <div class="staff-form-shell">
        <div class="staff-form-column">
            <div class="staff-glass-panel">
                <div class="staff-glass-panel-body">
                    <div class="staff-form-header">
                        <div>
                            <h2 class="staff-panel-title">Report Details</h2>
                            <p class="staff-page-subtitle mb-0">Capture the core title, department, and narrative behind this submission.</p>
                        </div>
                        <div class="staff-form-actions">
                            <a asp-action="GetMyReports" class="staff-outline-button">
                                <span class="material-symbols-outlined">draft</span>
                                <span>View Reports</span>
                            </a>
                            <button type="submit" class="staff-solid-button" id="submitBtn">
                                <span class="material-symbols-outlined">send</span>
                                <span>Submit Report</span>
                            </button>
                        </div>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="staff-form-group">
                        <label asp-for="Tittle" class="staff-form-label">Report Title</label>
                        <input asp-for="Tittle" class="staff-form-control" placeholder="e.g., Annual Technical Infrastructure Assessment Q3" maxlength="200" />
                        <span asp-validation-for="Tittle" class="text-danger small"></span>
                        <p class="staff-form-help">Please use a descriptive title following the institutional naming convention.</p>
                    </div>

                    <div class="staff-form-grid">
                        @* <div class="staff-form-group">
                            <label asp-for="DepartmentId" class="staff-form-label">Department</label>
                            <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="staff-form-select">
                                <option value="">Select Department</option>
                            </select>
                            <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                        </div> *@

                        <div class="staff-form-group">
                            <label class="staff-form-label">Category</label>
                            <select class="staff-form-select">
                                <option>Select Category</option>
                                <option>Academic Performance</option>
                                <option>Facility Audit</option>
                                <option>Technical Incident</option>
                                <option>Financial Summary</option>
                            </select>
                        </div>
                    </div>

                    <div class="staff-form-group">
                        <label asp-for="Content" class="staff-form-label">Content / Description</label>
                        <div class="staff-editor-shell">
                            <div class="staff-editor-toolbar">
                                <button type="button" class="staff-editor-tool" data-editor-action="bold" title="Bold">
                                    <span class="material-symbols-outlined">format_bold</span>
                                </button>
                                <button type="button" class="staff-editor-tool" data-editor-action="italic" title="Italic">
                                    <span class="material-symbols-outlined">format_italic</span>
                                </button>
                                <button type="button" class="staff-editor-tool" data-editor-action="bullets" title="Bullet list">
                                    <span class="material-symbols-outlined">format_list_bulleted</span>
                                </button>
                                <button type="button" class="staff-editor-tool" data-editor-action="link" title="Insert link">
                                    <span class="material-symbols-outlined">link</span>
                                </button>
                            </div>
                            <textarea asp-for="Content" id="reportContent" class="staff-form-textarea" placeholder="Provide a detailed description of the report's findings..."></textarea>
                        </div>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="staff-form-side">
            <div class="staff-glass-panel">
                <div class="staff-glass-panel-body">
                    <h2 class="staff-panel-title mb-3">Attachments</h2>
                    <label for="reportFile" class="staff-upload-zone d-block">
                        <span class="staff-upload-icon">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">upload_file</span>
                        </span>
                        <p class="fw-bold text-primary mb-1">Upload Files</p>
                        <p class="text-muted mb-2">Drag and drop or click to browse</p>
                        <p class="small text-muted mb-0">PDF, DOCX, XLSX, JPG, PNG or TXT</p>
                    </label>
                    <input asp-for="FileUrl" id="reportFile" type="file" name="file" class="d-none" />

                    <div class="staff-file-list" id="filePreview" hidden>
                        <div class="staff-file-item">
                            <div class="d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined text-primary">description</span>
                                <span class="small fw-semibold" id="fileName">No file selected</span>
                            </div>
                            <button type="button" class="btn btn-sm btn-link text-danger p-0 text-decoration-none" id="clearFile">
                                <span class="material-symbols-outlined">close</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="staff-glass-panel">
                <div class="staff-glass-panel-body">
                    <h2 class="staff-panel-title mb-3">Submission Guide</h2>
                    <ul class="staff-guide-list">
                        <li class="staff-guide-item">
                            <span class="material-symbols-outlined">check_circle</span>
                            <span>Ensure the report title clearly reflects the scope and reporting period.</span>
                        </li>
                        <li class="staff-guide-item">
                            <span class="material-symbols-outlined">check_circle</span>
                            <span>Include supporting documents where figures, evidence, or approvals are referenced.</span>
                        </li>
                        <li class="staff-guide-item">
                            <span class="material-symbols-outlined">check_circle</span>
                            <span>Review the narrative for an academic tone and institutional terminology before submission.</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="staff-visual-card">
                <img src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=1200&q=80" alt="Institutional workspace" />
                <div class="staff-visual-overlay">
                    <h3 class="mb-1 fw-bold">Academic Excellence</h3>
                    <p class="mb-0 small">Documenting progress for the current academic cycle with precision and clarity.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="staff-footer-meta">
        <span>System Version 4.2.1-stable • Masroor International Technical College</span>
        <div class="staff-footer-links">
            <span>Security Policy</span>
            <span>Privacy Standards</span>
        </div>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        (function () {
            const form = document.getElementById('reportForm');
            const submitBtn = document.getElementById('submitBtn');
            const fileInput = document.getElementById('reportFile');
            const filePreview = document.getElementById('filePreview');
            const fileName = document.getElementById('fileName');
            const clearFile = document.getElementById('clearFile');
            const contentField = document.getElementById('reportContent');
            const toolbarButtons = document.querySelectorAll('[data-editor-action]');

            form.addEventListener('submit', function () {
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span><span>Submitting...</span>';
            });

            fileInput.addEventListener('change', function () {
                const selectedFile = this.files && this.files[0];
                if (!selectedFile) {
                    filePreview.hidden = true;
                    return;
                }

                fileName.textContent = selectedFile.name;
                filePreview.hidden = false;
            });

            clearFile.addEventListener('click', function () {
                fileInput.value = '';
                filePreview.hidden = true;
            });

            function updateTextArea(nextValue, selectionStart, selectionEnd) {
                contentField.value = nextValue;
                contentField.focus();
                contentField.setSelectionRange(selectionStart, selectionEnd);
            }

            function wrapSelection(prefix, suffix, placeholder) {
                const start = contentField.selectionStart;
                const end = contentField.selectionEnd;
                const value = contentField.value;
                const selectedText = value.substring(start, end) || placeholder;
                const replacement = prefix + selectedText + suffix;
                const nextValue = value.substring(0, start) + replacement + value.substring(end);
                const cursorStart = start + prefix.length;
                const cursorEnd = cursorStart + selectedText.length;
                updateTextArea(nextValue, cursorStart, cursorEnd);
            }

            function insertBullets() {
                const start = contentField.selectionStart;
                const end = contentField.selectionEnd;
                const value = contentField.value;
                const selectedText = value.substring(start, end).trim();
                const lines = selectedText
                    ? selectedText.split(/\r?\n/).map(line => line.startsWith('- ') ? line : '- ' + line)
                    : ['- List item'];
                const replacement = lines.join('\n');
                const nextValue = value.substring(0, start) + replacement + value.substring(end);
                updateTextArea(nextValue, start, start + replacement.length);
            }

            function insertLink() {
                const start = contentField.selectionStart;
                const end = contentField.selectionEnd;
                const value = contentField.value;
                const selectedText = value.substring(start, end) || 'link text';
                const url = window.prompt('Enter the URL for this link:', 'https://');

                if (!url) {
                    contentField.focus();
                    return;
                }

                const replacement = '[' + selectedText + '](' + url + ')';
                const nextValue = value.substring(0, start) + replacement + value.substring(end);
                updateTextArea(nextValue, start, start + replacement.length);
            }

            toolbarButtons.forEach(function (button) {
                button.addEventListener('click', function () {
                    const action = button.getAttribute('data-editor-action');

                    if (action === 'bold') {
                        wrapSelection('**', '**', 'bold text');
                    } else if (action === 'italic') {
                        wrapSelection('*', '*', 'italic text');
                    } else if (action === 'bullets') {
                        insertBullets();
                    } else if (action === 'link') {
                        insertLink();
                    }
                });
            });
        })();
    </script>
}
