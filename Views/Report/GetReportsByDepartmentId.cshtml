@using MITCRMS.Models.DTOs
@using MITCRMS.Models.Enum
@model List<MITCRMS.Models.DTOs.Report.ReportDto>

@{
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
    ViewData["Title"] = "Department Reports";

    var reports = Model ?? new List<MITCRMS.Models.DTOs.Report.ReportDto>();
    var currentStatus = ViewBag.StatusFilter as string ?? string.Empty;
    var currentSearch = ViewBag.SearchTerm as string ?? string.Empty;
    var totalReports = reports.Count;
    var pendingReports = reports.Count(r => r.Status == ReportStatus.Pending);
    var approvedReports = reports.Count(r => r.Status == ReportStatus.Approved);
    var rejectedReports = reports.Count(r => r.Status == ReportStatus.Rejected);
    var recentContributors = reports
        .Select(r => r.User?.FullName ?? r.FullName)
        .Where(n => !string.IsNullOrWhiteSpace(n))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();
}

<section class="myreports-page">
    <div class="myreports-header">
        <div>
            <h1 class="myreports-title">Department Reports</h1>
            <p class="myreports-subtitle">Review all report submissions within your department and monitor team reporting progress.</p>
        </div>
        <div class="myreports-header-actions">
            <a asp-action="CreateReport" class="myreports-primary-button">
                <span class="material-symbols-outlined">add</span>
                <span>New Report</span>
            </a>
        </div>
    </div>

    <section class="myreports-summary-grid">
        <div class="myreports-summary-card">
            <span class="myreports-summary-label">Department Reports</span>
            <div class="myreports-summary-value">@totalReports</div>
            <p class="myreports-summary-note">Current report records across your department.</p>
        </div>
        <div class="myreports-summary-card">
            <span class="myreports-summary-label">Pending Review</span>
            <div class="myreports-summary-value text-primary">@pendingReports</div>
            <p class="myreports-summary-note">Still waiting for administrative approval.</p>
        </div>
        <div class="myreports-summary-card">
            <span class="myreports-summary-label">Approved</span>
            <div class="myreports-summary-value text-success">@approvedReports</div>
            <p class="myreports-summary-note">Reports already reviewed and accepted.</p>
        </div>
        <div class="myreports-summary-card">
            <span class="myreports-summary-label">Contributors</span>
            <div class="myreports-summary-value">@recentContributors</div>
            <p class="myreports-summary-note">Staff members represented in these submissions.</p>
        </div>
    </section>

    <section class="myreports-filter-card">
        <form method="get" asp-action="GetReportsByDepartmentId" class="myreports-filter-form">
            <div class="myreports-filter-search">
                <label for="search" class="myreports-filter-label">Search</label>
                <input id="search" name="search" value="@currentSearch" type="text" placeholder="Search titles, content, or tutor name..." />
            </div>
            <div class="myreports-filter-select">
                <label for="status" class="myreports-filter-label">Status</label>
                <select id="status" name="status">
                    <option value="" selected="@(string.IsNullOrWhiteSpace(currentStatus))">All Reports</option>
                    <option value="Approved" selected="@(currentStatus == "Approved")">Approved</option>
                    <option value="Pending" selected="@(currentStatus == "Pending")">Pending</option>
                    <option value="Rejected" selected="@(currentStatus == "Rejected")">Rejected</option>
                </select>
            </div>
            <div class="myreports-filter-actions">
                <a asp-action="GetReportsByDepartmentId" class="myreports-clear-link">Clear Filters</a>
                <button type="submit" class="myreports-apply-button">Apply</button>
            </div>
        </form>
    </section>

    <section class="myreports-table-card">
        @if (reports.Any())
        {
            <div class="table-responsive">
                <table class="myreports-table">
                    <thead>
                        <tr>
                            <th>Report ID</th>
                            <th>Title</th>
                            <th>Contributor</th>
                            <th>Date Submitted</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in reports.OrderByDescending(r => r.DateCreated))
                        {
                            var statusClass = report.Status switch
                            {
                                ReportStatus.Approved => "myreports-badge-approved",
                                ReportStatus.Rejected => "myreports-badge-rejected",
                                _ => "myreports-badge-pending"
                            };
                            var contributor = report.User?.FullName ?? report.FullName ?? "Unknown staff";
                            <tr>
                                <td class="myreports-id">#REP-@report.Id.ToString().Substring(0, 6).ToUpperInvariant()</td>
                                <td>
                                    <div class="myreports-title-wrap">
                                        <span class="myreports-title-text">@report.Tittle</span>
                                        <span class="myreports-title-meta">@report.DepartmentName</span>
                                    </div>
                                </td>
                                <td class="myreports-date">@contributor</td>
                                <td class="myreports-date">@report.DateCreated.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="myreports-badge @statusClass">@report.Status</span>
                                </td>
                                <td class="text-end">
                                    <div class="myreports-actions">
                                        <a asp-action="Details" asp-route-id="@report.Id" class="myreports-link-button">
                                            <span>View Details</span>
                                            <span class="material-symbols-outlined" style="font-size:16px;">chevron_right</span>
                                        </a>
                                        <a asp-action="DownloadPdf" asp-route-id="@report.Id" class="myreports-icon-button" title="Download PDF">
                                            <span class="material-symbols-outlined">download</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="myreports-table-footer">
                <span>Showing <strong>@reports.Count</strong> department result(s)</span>
            </div>
        }
        else
        {
            <div class="myreports-empty-state">
                <span class="material-symbols-outlined">folder_open</span>
                <h3>No department reports found</h3>
                <p>No report currently matches the selected department filters.</p>
            </div>
        }
    </section>

    <section class="myreports-help-grid">
        <div class="myreports-help-card myreports-help-primary">
            <div class="myreports-help-copy">
                <h3>Department overview in one place</h3>
                <p>Use this view to follow contributor activity, spot pending submissions early, and keep your department reporting cycle on track.</p>
                <a asp-action="CreateReport" class="myreports-help-button">Create Another Report</a>
            </div>
            <div class="myreports-help-icon">
                <span class="material-symbols-outlined">groups</span>
            </div>
        </div>
    </section>
</section>
