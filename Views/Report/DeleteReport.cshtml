@using MITCRMS.Models.DTOs;
@model BaseResponse<MITCRMS.Models.DTOs.Report.ReportDto>

@{
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
    ViewData["Title"] = "Delete Report";
}

<section class="staff-page-header">
    <div>
        <h1 class="staff-page-title text-danger">Delete Report</h1>
        <p class="staff-page-subtitle text-danger fw-semibold">Are you sure you want to permanently delete this report? This action cannot be undone.</p>
    </div>
</section>

<div class="staff-form-shell">
    <div class="staff-form-column">
        <div class="staff-glass-panel">
            <div class="staff-glass-panel-body">
                <div class="staff-form-header">
                    <div>
                        <h2 class="staff-panel-title">Report Confirmation</h2>
                        <p class="staff-page-subtitle mb-0">Please review the details of the report you are about to delete.</p>
                    </div>
                </div>

                <div class="mt-4">
                    <div class="staff-form-group">
                        <label class="staff-form-label">Report Title</label>
                        <div class="fs-4 fw-bold text-dark mb-1">@Model.Data.Tittle</div>
                    </div>

                    <div class="staff-form-grid mt-3">
                        <div class="staff-form-group">
                            <label class="staff-form-label">Submitted On</label>
                            <div class="text-muted">
                                <span class="material-symbols-outlined align-middle fs-5 me-1 text-muted">calendar_today</span>
                                @Model.Data.DateCreated.ToString("dd MMM yyyy (hh:mm tt)")
                            </div>
                        </div>

                        <div class="staff-form-group">
                            <label class="staff-form-label">Status</label>
                            <div>
                                @{
                                    var statusClass = Model.Data.Status.ToString().ToLower();
                                }
                                <span class="staff-status-badge staff-status-@statusClass">@Model.Data.Status</span>
                            </div>
                        </div>
                    </div>

                    <div class="staff-form-group mt-3">
                        <label class="staff-form-label">Content Narrative</label>
                        <div class="p-3 bg-light rounded-3 text-dark border-light-subtle" style="white-space: pre-wrap; min-height: 120px;">@Model.Data.Content</div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Data.FileUrl))
                    {
                        <div class="staff-form-group mt-4">
                            <label class="staff-form-label">Attachment</label>
                            <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3 border">
                                <span class="material-symbols-outlined text-primary fs-1">draft</span>
                                <div>
                                    <h6 class="mb-1 fw-bold text-dark">Uploaded File Attachment</h6>
                                    <a href="@Model.Data.FileUrl" download class="btn btn-sm btn-success d-inline-flex align-items-center gap-1">
                                        <span class="material-symbols-outlined fs-5">download</span>
                                        <span>Download Attachment</span>
                                    </a>
                                </div>
                            </div>
                            @if (Model.Data.FileUrl.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || 
                                 Model.Data.FileUrl.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || 
                                 Model.Data.FileUrl.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="mt-3 text-center">
                                    <img src="@Model.Data.FileUrl" alt="Report Attachment Preview" class="img-thumbnail" style="max-height: 240px;" />
                                </div>
                            }
                        </div>
                    }
                </div>

                <form asp-action="DeleteReport" method="post" class="mt-5 pt-3 border-top d-flex gap-2 justify-content-end">
                    <input type="hidden" asp-for="@Model.Data.Id" />
                    <a asp-action="GetMyReports" class="staff-outline-button text-decoration-none">
                        <span class="material-symbols-outlined">cancel</span>
                        <span>Cancel</span>
                    </a>
                    <button type="submit" class="staff-solid-button bg-danger text-white border-0" style="box-shadow: 0 12px 22px rgba(220, 53, 69, 0.25);">
                        <span class="material-symbols-outlined">delete</span>
                        <span>Delete Report</span>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="staff-form-side">
        <div class="staff-glass-panel mb-4">
            <div class="staff-glass-panel-body bg-danger bg-opacity-10 border-danger border-opacity-25 rounded-4">
                <h5 class="text-danger fw-bold d-flex align-items-center gap-2 mb-3">
                    <span class="material-symbols-outlined">warning</span>
                    <span>Confirm Action</span>
                </h5>
                <p class="text-danger-emphasis small mb-0">
                    Deleting a report removes its contents, timestamps, and upload history from the database. This report will no longer appear on dashboard metrics or department listings.
                </p>
            </div>
        </div>

        <div class="staff-glass-panel">
            <div class="staff-glass-panel-body">
                <h5 class="text-primary fw-bold d-flex align-items-center gap-2 mb-3">
                    <span class="material-symbols-outlined">info</span>
                    <span>Reporting Integrity</span>
                </h5>
                <p class="text-muted small mb-0">
                    Ensure that this report is no longer required by departmental supervisors or audits before completing the deletion.
                </p>
            </div>
        </div>
    </div>
</div>
