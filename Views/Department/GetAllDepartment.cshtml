@using MITCRMS.Models.DTOs
@model IEnumerable<MITCRMS.Models.DTOs.Department.DepartmentDto>

@{
    ViewData["Title"] = "Department Management";
    var departments = (Model ?? Enumerable.Empty<MITCRMS.Models.DTOs.Department.DepartmentDto>())
        .OrderBy(d => d.DepartmentName)
        .ToList();
    var totalDepartments = departments.Count;
    var recentDepartments = departments.Count(d => d.DateCreated >= DateTime.Now.AddDays(-30));
    var latestDepartment = departments.OrderByDescending(d => d.DateCreated).FirstOrDefault();
}

<section class="dept-page">
    <div class="dept-header">
        <div>
            <div class="dept-breadcrumb">Department Management</div>
            <h1 class="dept-title">Departments</h1>
            <p class="dept-subtitle">Manage academic and administrative departments across the reporting system.</p>
        </div>
        <a asp-action="CreateDepartment" asp-controller="Department" class="dept-primary-button">
            <span class="material-symbols-outlined">add</span>
            <span>Add Department</span>
        </a>
    </div>

    <section class="dept-summary-grid">
        <div class="dept-summary-card">
            <p class="dept-summary-label">Total Departments</p>
            <h2 class="dept-summary-value">@totalDepartments</h2>
            <p class="dept-summary-note">Current department records in the system.</p>
        </div>
        <div class="dept-summary-card">
            <p class="dept-summary-label">New This Month</p>
            <h2 class="dept-summary-value">@recentDepartments</h2>
            <p class="dept-summary-note">Departments created in the last 30 days.</p>
        </div>
        <div class="dept-summary-card">
            <p class="dept-summary-label">Latest Department</p>
            <h2 class="dept-summary-value dept-summary-text">@(latestDepartment?.DepartmentCode?.ToUpper() ?? "N/A")</h2>
            <p class="dept-summary-note">@(latestDepartment?.DepartmentName ?? "No recent record")</p>
        </div>
    </section>

    <section class="dept-table-card">
        <div class="dept-table-head">
            <div>
                <h2>Department Directory</h2>
                <p>Showing <strong>@totalDepartments</strong> department(s) in the current workspace.</p>
            </div>
        </div>

        @if (departments.Any())
        {
            <div class="table-responsive">
                <table class="dept-table">
                    <thead>
                        <tr>
                            <th>S/N</th>
                            <th>Department</th>
                            <th>Code</th>
                            <th>Date Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var count = 1;
                        }
                        @foreach (var department in departments)
                        {
                            <tr>
                                <td class="dept-serial">@count</td>
                                <td>
                                    <div class="dept-name-block">
                                        <span class="dept-avatar">@((department.DepartmentName ?? "D").Substring(0, 1).ToUpper())</span>
                                        <div>
                                            <span class="dept-name">@department.DepartmentName</span>
                                            <span class="dept-meta">Department record</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="dept-code-chip">@department.DepartmentCode?.ToUpper()</span>
                                </td>
                                <td class="dept-date">@department.DateCreated.ToString("dd MMM yyyy")</td>
                                <td class="text-end">
                                    <div class="dept-actions">
                                        <a asp-action="DeleteDepartment" asp-route-id="@department.Id" class="dept-action-button dept-action-danger" title="Delete department">
                                            <span class="material-symbols-outlined">delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            count++;
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="dept-empty-state">
                <span class="material-symbols-outlined">domain_disabled</span>
                <h3>No departments found</h3>
                <p>Create the first department to start organizing staff and reports properly.</p>
                <a asp-action="CreateDepartment" asp-controller="Department" class="dept-primary-button mt-3">
                    <span class="material-symbols-outlined">add</span>
                    <span>Create Department</span>
                </a>
            </div>
        }
    </section>
</section>

<style>
    .dept-page {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .dept-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 18px;
    }

    .dept-breadcrumb {
        color: #747683;
        font-size: 0.8rem;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .dept-title {
        margin: 0;
        color: #204098;
        font-size: clamp(2rem, 2.4vw, 2.5rem);
        font-weight: 800;
    }

    .dept-subtitle {
        margin: 8px 0 0;
        color: #556070;
    }

    .dept-primary-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 13px 18px;
        border-radius: 16px;
        background: linear-gradient(135deg, #204098 0%, #3c59b1 100%);
        color: #ffffff;
        text-decoration: none;
        font-weight: 700;
        box-shadow: 0 12px 22px rgba(37, 68, 156, 0.2);
    }

    .dept-summary-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 24px;
    }

    .dept-summary-card,
    .dept-table-card {
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid rgba(207, 214, 226, 0.82);
        border-radius: 22px;
        box-shadow: 0 18px 34px rgba(24, 33, 74, 0.08);
    }

    .dept-summary-card {
        padding: 24px;
    }

    .dept-summary-label {
        margin: 0 0 12px;
        color: #747683;
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .dept-summary-value {
        margin: 0 0 8px;
        color: #204098;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1;
        font-weight: 800;
    }

    .dept-summary-text {
        font-size: 2rem;
    }

    .dept-summary-note {
        margin: 0;
        color: #556070;
    }

    .dept-table-head {
        padding: 24px;
        border-bottom: 1px solid rgba(207, 214, 226, 0.68);
    }

    .dept-table-head h2 {
        margin: 0 0 6px;
        color: #204098;
        font-size: 1.15rem;
        font-weight: 800;
    }

    .dept-table-head p {
        margin: 0;
        color: #556070;
    }

    .dept-table {
        width: 100%;
        border-collapse: collapse;
    }

    .dept-table thead {
        background: rgba(244, 242, 252, 0.72);
    }

    .dept-table th,
    .dept-table td {
        padding: 16px 24px;
        vertical-align: middle;
    }

    .dept-table th {
        color: #747683;
        font-size: 0.76rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        white-space: nowrap;
    }

    .dept-table tbody tr {
        border-top: 1px solid rgba(207, 214, 226, 0.64);
    }

    .dept-table tbody tr:nth-child(even) {
        background: rgba(248, 250, 255, 0.72);
    }

    .dept-table tbody tr:hover {
        background: rgba(244, 242, 252, 0.58);
    }

    .dept-serial,
    .dept-date {
        color: #334155;
        font-weight: 700;
    }

    .dept-name-block {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .dept-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #dce1ff;
        color: #204098;
        font-weight: 800;
    }

    .dept-name {
        display: block;
        color: #1a1b22;
        font-weight: 700;
    }

    .dept-meta {
        display: block;
        margin-top: 3px;
        color: #747683;
        font-size: 0.76rem;
    }

    .dept-code-chip {
        display: inline-flex;
        align-items: center;
        padding: 7px 12px;
        border-radius: 999px;
        background: #dbe1ff;
        color: #204098;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .dept-actions {
        display: inline-flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
    }

    .dept-action-button {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        background: transparent;
    }

    .dept-action-danger {
        color: #a32d1a;
    }

    .dept-action-danger:hover {
        background: #ffded7;
    }

    .dept-empty-state {
        padding: 56px 24px;
        text-align: center;
    }

    .dept-empty-state .material-symbols-outlined {
        font-size: 52px;
        color: #899ad7;
    }

    .dept-empty-state h3 {
        margin: 14px 0 8px;
        color: #204098;
        font-weight: 800;
    }

    .dept-empty-state p {
        margin: 0;
        color: #556070;
    }

    @@media (max-width: 1199.98px) {
        .dept-summary-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 767.98px) {
        .dept-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
