@model MITCRMS.Models.DTOs.Department.DepartmentDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Department Details";
}

<section class="dept-create-page">
    <div class="dept-create-header">
        <div>
            <div class="dept-create-breadcrumb">Department Management / Details</div>
            <h1 class="dept-create-title">@Model.DepartmentName</h1>
            <p class="dept-create-subtitle">Detailed information about this academic or administrative department.</p>
        </div>
        <a asp-action="GetAllDepartment" class="dept-create-secondary text-decoration-none">
            <span class="material-symbols-outlined">arrow_back</span>
            <span>Back to Departments</span>
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
            <span class="material-symbols-outlined me-2">error</span>
            <span>@TempData["ErrorMessage"]</span>
        </div>
    }

    <div class="dept-create-grid">
        <div class="dept-create-card">
            <div class="d-flex align-items-center gap-3 mb-4 pb-3 border-bottom">
                <span class="dept-avatar fs-2 p-3" style="width: 64px; height: 64px; border-radius: 16px; background: var(--admin-primary-soft); color: var(--admin-primary); display: flex; align-items: center; justify-content: center; font-weight: 800;">
                    @((Model.DepartmentName ?? "D").Substring(0, 1).ToUpper())
                </span>
                <div>
                    <h3 class="fw-bold text-dark mb-1">@Model.DepartmentName</h3>
                    <span class="badge bg-primary px-3 py-2 fs-6">@Model.DepartmentCode?.ToUpper()</span>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="dept-create-group">
                        <label class="dept-create-label">Department ID</label>
                        <div class="form-control-plaintext text-muted small text-break">@Model.Id</div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="dept-create-group">
                        <label class="dept-create-label">Created On</label>
                        <div class="form-control-plaintext text-dark">
                            <span class="material-symbols-outlined align-middle fs-5 me-1 text-muted">calendar_today</span>
                            @Model.DateCreated.ToString("dd MMM yyyy (hh:mm tt)")
                        </div>
                    </div>
                </div>
            </div>

            <div class="dept-create-actions mt-5 pt-3 border-top">
                <a asp-action="GetAllDepartment" class="dept-create-reset text-decoration-none">
                    <span class="material-symbols-outlined">arrow_back</span>
                    <span>Back to Directory</span>
                </a>
                <a asp-action="DeleteDepartment" asp-route-id="@Model.Id" class="dept-create-submit bg-danger text-white border-0 text-decoration-none" style="box-shadow: 0 12px 22px rgba(220, 53, 69, 0.25);">
                    <span class="material-symbols-outlined">delete</span>
                    <span>Delete Department</span>
                </a>
            </div>
        </div>

        <div class="dept-create-side">
            <div class="dept-create-note-card">
                <h2>Quick Overview</h2>
                <p>This department is an active unit within the college reporting system. Staff assigned to this department are permitted to compile and submit monthly reports for HOD and admin review.</p>
            </div>

            <div class="dept-create-note-card dept-create-note-warning">
                <h2>Important Actions</h2>
                <p>Deleting this department is highly destructive. Ensure that no active reports, staff, or courses are assigned to this department before initiating a delete.</p>
            </div>
        </div>
    </div>
</section>