@model MITCRMS.Models.DTOs.Department.CreateDepartmentRequestModel

@{
    ViewData["Title"] = "Create Department";
}

<section class="dept-create-page">
    <div class="dept-create-header">
        <div>
            <div class="dept-create-breadcrumb">Department Management / Create</div>
            <h1 class="dept-create-title">Add New Department</h1>
            <p class="dept-create-subtitle">Create a clean department record for report assignment, staff organization, and administrative structure.</p>
        </div>
        <a asp-action="GetAllDepartment" class="dept-create-secondary">
            <span class="material-symbols-outlined">arrow_back</span>
            <span>Back to Departments</span>
        </a>
    </div>

    <div class="dept-create-grid">
        <div class="dept-create-card">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            @if (ViewBag.Success != null)
            {
                <div class="alert alert-success">@ViewBag.Success</div>
            }

            <form asp-action="CreateDepartment" method="post" id="departmentForm">
                <div class="dept-create-group">
                    <label asp-for="DepartmentName" class="dept-create-label">Department Name</label>
                    <input asp-for="DepartmentName" class="dept-create-control" id="departmentNameInput" placeholder="Enter department name" />
                    <span asp-validation-for="DepartmentName" class="text-danger small"></span>
                    <div class="dept-create-helper">
                        <span><span id="charCount">0</span> / 100 characters</span>
                        <span id="customValidation"></span>
                    </div>
                </div>

                <div class="dept-create-group">
                    <label asp-for="DepartmentCode" class="dept-create-label">Department Code</label>
                    <input asp-for="DepartmentCode" class="dept-create-control" id="departmentCodeInput" placeholder="Enter department code" />
                    <span asp-validation-for="DepartmentCode" class="text-danger small"></span>
                </div>

                <div class="dept-create-actions">
                    <button type="reset" class="dept-create-reset" id="resetBtn">
                        <span class="material-symbols-outlined">restart_alt</span>
                        <span>Reset</span>
                    </button>
                    <button type="submit" class="dept-create-submit" id="submitBtn">
                        <span class="material-symbols-outlined">save</span>
                        <span>Add Department</span>
                    </button>
                </div>
            </form>
        </div>

        <div class="dept-create-side">
            <div class="dept-create-note-card">
                <h2>Quick Tips</h2>
                <ul>
                    <li>Use clear, recognizable names for easier navigation across reports and staff records.</li>
                    <li>Keep department codes short, consistent, and unique.</li>
                    <li>Department names should match institutional terminology already used internally.</li>
                </ul>
            </div>

            <div class="dept-create-note-card dept-create-note-warning">
                <h2>Important</h2>
                <p>Department names and codes should not duplicate existing records. Validate naming before saving.</p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const departmentInput = document.getElementById('departmentNameInput');
            const charCount = document.getElementById('charCount');
            const form = document.getElementById('departmentForm');
            const submitBtn = document.getElementById('submitBtn');
            const resetBtn = document.getElementById('resetBtn');
            const customValidation = document.getElementById('customValidation');

            function validateInput() {
                const value = departmentInput.value.trim();
                customValidation.textContent = '';
                departmentInput.classList.remove('is-invalid', 'is-valid');

                if (value === '') {
                    departmentInput.classList.add('is-invalid');
                    customValidation.textContent = 'Department name cannot be empty';
                    return false;
                }

                if (value.length < 2) {
                    departmentInput.classList.add('is-invalid');
                    customValidation.textContent = 'Department name must be at least 2 characters';
                    return false;
                }

                if (value.length > 100) {
                    departmentInput.classList.add('is-invalid');
                    customValidation.textContent = 'Department name cannot exceed 100 characters';
                    return false;
                }

                const validPattern = /^[a-zA-Z0-9\s\-&]+$/;
                if (!validPattern.test(value)) {
                    departmentInput.classList.add('is-invalid');
                    customValidation.textContent = 'Only letters, numbers, spaces, hyphens, and ampersands are allowed';
                    return false;
                }

                departmentInput.classList.add('is-valid');
                return true;
            }

            departmentInput.addEventListener('input', function () {
                charCount.textContent = this.value.length;
                validateInput();
            });

            form.addEventListener('submit', function (e) {
                if (!validateInput()) {
                    e.preventDefault();
                    return;
                }

                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span><span>Adding...</span>';
            });

            resetBtn.addEventListener('click', function () {
                setTimeout(function () {
                    charCount.textContent = '0';
                    customValidation.textContent = '';
                    departmentInput.classList.remove('is-invalid', 'is-valid');
                }, 10);
            });

            window.addEventListener('load', function () {
                departmentInput.focus();
            });
        })();
    </script>
}

<style>
    .dept-create-page {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .dept-create-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 18px;
    }

    .dept-create-breadcrumb {
        color: #747683;
        font-size: 0.8rem;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .dept-create-title {
        margin: 0;
        color: #204098;
        font-size: clamp(2rem, 2.4vw, 2.5rem);
        font-weight: 800;
    }

    .dept-create-subtitle {
        margin: 8px 0 0;
        color: #556070;
        max-width: 720px;
    }

    .dept-create-grid {
        display: grid;
        grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
        gap: 24px;
    }

    .dept-create-card,
    .dept-create-note-card {
        background: rgba(255, 255, 255, 0.94);
        border: 1px solid rgba(207, 214, 226, 0.82);
        border-radius: 22px;
        box-shadow: 0 18px 34px rgba(24, 33, 74, 0.08);
    }

    .dept-create-card {
        padding: 24px;
    }

    .dept-create-group + .dept-create-group {
        margin-top: 20px;
    }

    .dept-create-label {
        display: block;
        margin-bottom: 8px;
        color: #556070;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .dept-create-control {
        width: 100%;
        border: 1px solid rgba(196, 197, 212, 0.88);
        border-radius: 16px;
        background: #ffffff;
        padding: 14px 16px;
        outline: none;
        transition: all 0.18s ease;
    }

    .dept-create-control:focus {
        border-color: rgba(60, 89, 177, 0.45);
        box-shadow: 0 0 0 4px rgba(60, 89, 177, 0.08);
    }

    .dept-create-helper {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        margin-top: 8px;
        color: #747683;
        font-size: 0.78rem;
    }

    .dept-create-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid rgba(207, 214, 226, 0.7);
    }

    .dept-create-secondary,
    .dept-create-reset,
    .dept-create-submit {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 12px 18px;
        border-radius: 14px;
        font-weight: 700;
        text-decoration: none;
    }

    .dept-create-secondary,
    .dept-create-reset {
        border: 1px solid rgba(196, 197, 212, 0.8);
        color: #204098;
        background: rgba(255, 255, 255, 0.8);
    }

    .dept-create-submit {
        border: 0;
        color: #ffffff;
        background: linear-gradient(135deg, #204098 0%, #3c59b1 100%);
        box-shadow: 0 12px 22px rgba(37, 68, 156, 0.2);
    }

    .dept-create-side {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .dept-create-note-card {
        padding: 24px;
    }

    .dept-create-note-card h2 {
        margin: 0 0 14px;
        color: #204098;
        font-size: 1.05rem;
        font-weight: 800;
    }

    .dept-create-note-card ul {
        margin: 0;
        padding-left: 18px;
        color: #556070;
        line-height: 1.8;
    }

    .dept-create-note-card p {
        margin: 0;
        color: #556070;
        line-height: 1.7;
    }

    .dept-create-note-warning {
        border-left: 4px solid #f0a500;
    }

    @@media (max-width: 991.98px) {
        .dept-create-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 767.98px) {
        .dept-create-header,
        .dept-create-actions {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
