@using MITCRMS.Models.DTOs.Department
@model DepartmentDto         

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Delete Department";
}

<h2>@ViewData["Title"]</h2>
<h4>Are you sure you want to delete this Department?</h4>

<div class="p-3">
    <h2>@Model.DepartmentName</h2>
</div>

<div class="card p-3">
    <p><b>Department Code:</b> @Model.DepartmentCode</p>
</div>

<p><b>Created:</b> @Model.DateCreated.ToString("g")</p>

<form asp-action="DeleteReport" method="post">
    <input type="hidden" asp-for="@Model.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>

    <a asp-action="GetAllDepartment" class="btn btn-secondary ms-2">Cancel</a>
</form>