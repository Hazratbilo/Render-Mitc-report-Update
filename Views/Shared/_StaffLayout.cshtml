@using System.Security.Claims
@{
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var fullName = User.FindFirstValue(ClaimTypes.GivenName) ?? User.Identity?.Name ?? "Staff User";
    var firstName = User.FindFirstValue(ClaimTypes.Name) ?? fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "Staff";
    var roles = User.FindAll(ClaimTypes.Role).Select(r => r.Value).ToList();
    var roleLabel = roles.FirstOrDefault() ?? "Staff";
    var initials = string.Join("", fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => char.ToUpperInvariant(x[0])));
    var currentSearch = ViewBag.SearchTerm as string ?? string.Empty;

    bool IsActive(string targetController, params string[] targetActions)
    {
        return controller.Equals(targetController, StringComparison.OrdinalIgnoreCase)
            && targetActions.Any(a => action.Equals(a, StringComparison.OrdinalIgnoreCase));
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Staff Portal</title>
    <link rel="icon" type="image/png" href="~/Mitc_Logo-removebg-preview.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/staff-portal.css" asp-append-version="true" />
</head>
<body class="staff-portal-body">
    <div class="staff-portal-shell">
        <aside class="staff-portal-sidebar" id="staffPortalSidebar">
            <div class="staff-portal-brand">
                <img src="~/Mitc_Logo-removebg-preview.png" alt="MITC Logo" />
                <div class="staff-portal-brand-copy">
                    <h1>MITCRMS</h1>
                    <p>Academic Portal</p>
                </div>
            </div>

            <nav class="staff-portal-nav">
                <div class="staff-portal-nav-label">Workspace</div>
                <a asp-controller="User" asp-action="StaffDashboard" class="staff-portal-nav-link @(IsActive("User", "StaffDashboard") ? "is-active" : "")">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span>Dashboard</span>
                </a>
                <a asp-controller="Report" asp-action="GetMyReports" class="staff-portal-nav-link @(IsActive("Report", "GetMyReports", "Details", "DeleteReport") ? "is-active" : "")">
                    <span class="material-symbols-outlined">analytics</span>
                    <span>My Reports</span>
                </a>
                @if (roles.Any(r => r.Equals("Hod", StringComparison.OrdinalIgnoreCase)))
                {
                    <a asp-controller="Report" asp-action="GetReportsByDepartmentId" class="staff-portal-nav-link @(IsActive("Report", "GetReportsByDepartmentId") ? "is-active" : "")">
                        <span class="material-symbols-outlined">domain</span>
                        <span>Department Reports</span>
                    </a>
                }
            </nav>

            <a asp-controller="Report" asp-action="CreateReport" class="staff-portal-primary-action">
                <span class="material-symbols-outlined">add</span>
                <span>New Report</span>
            </a>

            <div class="staff-portal-bottom-links">
                @* <a asp-controller="Report" asp-action="CreateReport" class="staff-portal-nav-link @(IsActive("Report", "CreateReport") ? "is-active" : "")">
                    <span class="material-symbols-outlined">post_add</span>
                    <span>Create Report</span>
                </a> *@
                <a asp-controller="User" asp-action="Logout" class="staff-portal-nav-link">
                    <span class="material-symbols-outlined">logout</span>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <div class="staff-portal-main">
            <header class="staff-portal-header">
                <div class="staff-portal-header-left">
                    <button class="staff-portal-menu-toggle" type="button" id="staffPortalMenuToggle" aria-label="Toggle menu">
                        <span class="material-symbols-outlined">menu</span>
                    </button>
                    @* <a asp-controller="User" asp-action="StaffDashboard" class="staff-portal-header-title text-decoration-none">Reporting System</a> *@
                    <form asp-controller="Report" asp-action="GetMyReports" method="get" class="staff-portal-search">
                        <span class="material-symbols-outlined">search</span>
                        <input type="text" name="search" value="@currentSearch" placeholder="Search reports, submissions, or activity..." />
                    </form>
                </div>

                <div class="staff-portal-header-right">
                    <a asp-controller="Report" asp-action="GetMyReports" asp-route-status="Pending" class="staff-portal-icon-button" aria-label="Pending reports">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="staff-portal-notice-dot"></span>
                    </a>
                    <a asp-controller="Report" asp-action="CreateReport" class="staff-portal-icon-button" aria-label="Create report">
                        <span class="material-symbols-outlined">help</span>
                    </a>
                    <div class="staff-portal-user">
                        <div class="staff-portal-user-meta">
                            <span class="staff-portal-user-name">@fullName</span>
                            <span class="staff-portal-user-role">@roleLabel</span>
                        </div>
                        <span class="staff-portal-avatar">@initials</span>
                    </div>
                </div>
            </header>

            <main class="staff-portal-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            const sidebar = document.getElementById('staffPortalSidebar');
            const toggle = document.getElementById('staffPortalMenuToggle');

            if (toggle && sidebar) {
                toggle.addEventListener('click', function () {
                    sidebar.classList.toggle('is-open');
                });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
