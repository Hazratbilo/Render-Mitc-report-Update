@using System.Security.Claims
@{
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var fullName = User.FindFirstValue(ClaimTypes.GivenName) ?? User.Identity?.Name ?? "Admin Profile";
    var initials = string.Join("", fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => char.ToUpperInvariant(x[0])));
    var currentSearch = ViewBag.SearchTerm as string ?? string.Empty;

    bool IsActive(string targetController, params string[] targetActions)
    {
        return controller.Equals(targetController, StringComparison.OrdinalIgnoreCase)
            && targetActions.Any(a => action.Equals(a, StringComparison.OrdinalIgnoreCase));
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Super Admin</title>
    <link rel="icon" type="image/png" href="~/Mitc_Logo-removebg-preview.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin-portal.css" asp-append-version="true" />
</head>
<body class="admin-portal-body">
    <div class="admin-portal-shell">
        <aside class="admin-portal-sidebar" id="adminPortalSidebar">
            <div class="admin-portal-brand">
                <h1>MITCRMS</h1>
                <p>Academic Portal</p>
            </div>

            <nav class="admin-portal-nav">
                <a asp-controller="User" asp-action="SuperAdminDashboard" class="admin-portal-nav-link @(IsActive("User", "SuperAdminDashboard") ? "is-active" : "")">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span>Dashboard</span>
                </a>
                <a asp-controller="Report" asp-action="GetAllReports" class="admin-portal-nav-link @(IsActive("Report", "GetAllReports", "Details") ? "is-active" : "")">
                    <span class="material-symbols-outlined">analytics</span>
                    <span>Reports</span>
                </a>
                <a asp-controller="User" asp-action="GetAllUsersWithRoles" class="admin-portal-nav-link @(IsActive("User", "GetAllUsersWithRolesAsync", "CreateUser", "DeleteUser", "Details") ? "is-active" : "")">
                    <span class="material-symbols-outlined">badge</span>
                    <span>Staff Management</span>
                </a>
                <a asp-controller="Department" asp-action="GetAllDepartment" class="admin-portal-nav-link @(IsActive("Department", "GetAllDepartment", "CreateDepartment", "DeleteDepartment") ? "is-active" : "")">
                    <span class="material-symbols-outlined">domain</span>
                    <span>Department Management</span>
                </a>
            </nav>

            <a asp-controller="User" asp-action="CreateUser" class="admin-portal-primary-action">
                <span class="material-symbols-outlined">add</span>
                <span>Create Staff</span>
            </a>

            <div class="admin-portal-bottom-links">
                <a asp-controller="Department" asp-action="CreateDepartment" class="admin-portal-nav-link">
                    <span class="material-symbols-outlined">apartment</span>
                    <span>New Department</span>
                </a>
                <a asp-controller="User" asp-action="Logout" class="admin-portal-nav-link">
                    <span class="material-symbols-outlined">logout</span>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <div class="admin-portal-main">
            <header class="admin-portal-header">
                <div class="admin-portal-header-left">
                    <button class="admin-portal-menu-toggle" type="button" id="adminPortalMenuToggle" aria-label="Toggle admin menu">
                        <span class="material-symbols-outlined">menu</span>
                    </button>
                    <form asp-controller="Report" asp-action="GetAllReports" method="get" class="admin-portal-search">
                        <span class="material-symbols-outlined">search</span>
                        <input type="text" name="search" value="@currentSearch" placeholder="Search system records..." />
                    </form>
                    <a asp-controller="User" asp-action="SuperAdminDashboard" class="admin-portal-header-title">Reporting System</a>
                </div>

                <div class="admin-portal-header-right">
                    <a asp-controller="Report" asp-action="GetAllReports" asp-route-status="Pending" class="admin-portal-icon-button" aria-label="Pending approvals">
                        <span class="material-symbols-outlined">notifications</span>
                    </a>
                    <a asp-controller="User" asp-action="CreateUser" class="admin-portal-icon-button" aria-label="Create staff">
                        <span class="material-symbols-outlined">help</span>
                    </a>
                    <a asp-controller="Department" asp-action="CreateDepartment" class="admin-portal-icon-button" aria-label="Create department">
                        <span class="material-symbols-outlined">apps</span>
                    </a>
                    <div class="admin-portal-user">
                        <span class="admin-portal-user-name">@fullName</span>
                        <span class="admin-portal-avatar">@initials</span>
                    </div>
                </div>
            </header>

            <main class="admin-portal-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            const sidebar = document.getElementById('adminPortalSidebar');
            const toggle = document.getElementById('adminPortalMenuToggle');

            if (toggle && sidebar) {
                toggle.addEventListener('click', function () {
                    sidebar.classList.toggle('is-open');
                });
            }
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
