@using MITCRMS.Models.DTOs.Report
@using MITCRMS.Models.Enum
@model IEnumerable<ReportDto>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Super Admin Dashboard";

    var reports = (Model ?? Enumerable.Empty<ReportDto>())
        .OrderByDescending(r => r.DateCreated)
        .ToList();

    var totalReports = reports.Count;
    var pendingReports = reports.Count(r => r.Status == ReportStatus.Pending);
    var approvedReports = reports.Count(r => r.Status == ReportStatus.Approved);
    var rejectedReports = reports.Count(r => r.Status == ReportStatus.Rejected);
    var activeStaff = reports.Select(r => r.FullName).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct(StringComparer.OrdinalIgnoreCase).Count();
    var activeDepartments = reports.Select(r => r.DepartmentName).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct(StringComparer.OrdinalIgnoreCase).Count();
    var pendingApprovalRows = reports.Where(r => r.Status == ReportStatus.Pending).Take(4).ToList();
    var groupedDepartments = reports
        .Where(r => !string.IsNullOrWhiteSpace(r.DepartmentName))
        .GroupBy(r => r.DepartmentName)
        .Select(g => new { Department = g.Key, Count = g.Count(), Approved = g.Count(x => x.Status == ReportStatus.Approved) })
        .OrderByDescending(x => x.Count)
        .Take(4)
        .ToList();
    var highestDepartmentCount = groupedDepartments.Any() ? groupedDepartments.Max(x => x.Count) : 1;
}

<section class="admin-page-header">
    <div>
        <h1 class="admin-page-title">Super Admin Dashboard</h1>
        <p class="admin-page-subtitle">
            Monitor approvals, staff activity, departmental reporting volume, and the overall health of the reporting workflow from one control center.
        </p>
    </div>
</section>

<section class="admin-metrics-grid">
    <a asp-controller="Report" asp-action="GetAllReports" class="admin-metric-card text-decoration-none">
        <span class="admin-metric-label">Total Reports</span>
        <h2 class="admin-metric-value">@totalReports</h2>
        <span class="admin-metric-note">Full reporting volume across the portal</span>
    </a>

    <a asp-controller="Report" asp-action="GetAllReports" asp-route-status="Pending" class="admin-metric-card admin-metric-emphasis text-decoration-none">
        <span class="admin-metric-label">Pending Approval</span>
        <h2 class="admin-metric-value">@pendingReports</h2>
        <span class="admin-metric-note">Requires immediate review attention</span>
    </a>

    <a asp-controller="User" asp-action="GetAllUsersWithRoles" class="admin-metric-card text-decoration-none">
        <span class="admin-metric-label">Active Staff</span>
        <h2 class="admin-metric-value">@activeStaff</h2>
        <span class="admin-metric-note">Staff represented in recent submissions</span>
    </a>

    <a asp-controller="Department" asp-action="GetAllDepartment" class="admin-metric-card text-decoration-none">
        <span class="admin-metric-label">Total Departments</span>
        <h2 class="admin-metric-value">@activeDepartments</h2>
        <span class="admin-metric-note">Academic and administrative units</span>
    </a>
</section>

<section class="admin-dashboard-grid">
    <div class="admin-panel">
        <div class="admin-panel-header">
            <h2 class="admin-panel-title">Priority Pending Approvals</h2>
            <a asp-controller="Report" asp-action="GetAllReports" asp-route-status="Pending" class="admin-panel-link">View All Reports</a>
        </div>

        @if (pendingApprovalRows.Any())
        {
            <div class="admin-table-wrap">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Report ID</th>
                            <th>Department</th>
                            <th>Submitted By</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in pendingApprovalRows)
                        {
                            var ageInDays = Math.Max((DateTime.UtcNow - report.DateCreated.ToUniversalTime()).Days, 0);
                            var severityClass = ageInDays >= 3 ? "admin-severity-high" : "admin-severity-medium";
                            var severityLabel = ageInDays >= 3 ? "Critical" : "Medium";
                            <tr>
                                <td>#REP-@report.Id.ToString().Substring(0, 6).ToUpperInvariant()</td>
                                <td>@report.DepartmentName</td>
                                <td>@report.FullName</td>
                                <td>@report.DateCreated.ToString("dd MMM yyyy")</td>
                                <td><span class="admin-severity @severityClass">@severityLabel</span></td>
                                <td>
                                    <a asp-controller="Report" asp-action="Details" asp-route-id="@report.Id" class="admin-action-button" title="View report">
                                        <span class="material-symbols-outlined">visibility</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-4 text-muted">No pending approvals at the moment.</div>
        }
    </div>

    <div class="admin-panel">
        <div class="admin-panel-header">
            <h2 class="admin-panel-title">System Activity</h2>
            <span class="material-symbols-outlined text-muted">history</span>
        </div>

        <div class="admin-activity-list">
            <div class="admin-activity-item">
                <span class="admin-activity-marker admin-activity-primary">
                    <span class="material-symbols-outlined">add</span>
                </span>
                <div class="admin-activity-copy">
                    <p><strong>Staff activity:</strong> New staff records can be created directly from this dashboard.</p>
                    <small>Administrative action</small>
                </div>
            </div>

            <div class="admin-activity-item">
                <span class="admin-activity-marker admin-activity-success">
                    <span class="material-symbols-outlined">check_circle</span>
                </span>
                <div class="admin-activity-copy">
                    <p><strong>Approved reports:</strong> @approvedReports report(s) have already cleared review.</p>
                    <small>Workflow health snapshot</small>
                </div>
            </div>

            <div class="admin-activity-item">
                <span class="admin-activity-marker admin-activity-danger">
                    <span class="material-symbols-outlined">warning</span>
                </span>
                <div class="admin-activity-copy">
                    <p><strong>Reports needing attention:</strong> @pendingReports pending and @rejectedReports rejected entries are still in the pipeline.</p>
                    <small>Review queue summary</small>
                </div>
            </div>
        </div>

        @* <button type="button" class="admin-audit-button">Download Audit Log</button> *@
    </div>
</section>

<section class="admin-panel admin-distribution-panel">
    <div class="admin-distribution-head">
        <div>
            <h2 class="admin-panel-title">Reports Distribution</h2>
            <p class="admin-page-subtitle mb-0">Volume of reports per department based on the current system data.</p>
        </div>
    </div>

    @if (groupedDepartments.Any())
    {
        @foreach (var item in groupedDepartments)
        {
            var width = highestDepartmentCount == 0 ? 0 : (int)Math.Round((double)item.Count / highestDepartmentCount * 100);
            <div class="admin-distribution-item">
                <div class="admin-distribution-label">
                    <span>@item.Department</span>
                    <span>@item.Count report(s)</span>
                </div>
                <div class="admin-distribution-track">
                    <div class="admin-distribution-fill" style="width:@width%"></div>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted mb-0">No departmental report data is available yet.</p>
    }
</section>
