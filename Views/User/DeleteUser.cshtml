@using MITCRMS.Models.DTOs
@model BaseResponse<MITCRMS.Models.DTOs.Users.UserDto>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Delete Staff";
    ViewData["Title"] = "Delete Staff";
}

<div class="container mt-4">

    <h2>@ViewData["Title"]</h2>
    <h4 class="text-danger">Are you sure you want to delete this staff member?</h4>

    <div class="card shadow-sm mt-3">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">
                <i class="bi bi-person-x me-2"></i>@Model.Data.FullName
            </h5>
        </div>

        <div class="card-body">

            <div class="p-3">
                <h5>@Model.Data.FullName</h5>
            </div>

            <dl class="row px-3">
                <dt class="col-sm-3 text-muted">First Name</dt>
                <dd class="col-sm-9">@Model.Data.FirstName</dd>

                <dt class="col-sm-3 text-muted">Last Name</dt>
                <dd class="col-sm-9">@Model.Data.LastName</dd>

                <dt class="col-sm-3 text-muted">Email</dt>
                <dd class="col-sm-9">
                    <a href="mailto:@Model.Data.Email">@Model.Data.Email</a>
                </dd>

                <dt class="col-sm-3 text-muted">Phone</dt>
                <dd class="col-sm-9">
                    <a href="tel:@Model.Data.PhoneNumber">@Model.Data.PhoneNumber</a>
                </dd>

                <dt class="col-sm-3 text-muted">Address</dt>
                <dd class="col-sm-9">
                    @(string.IsNullOrWhiteSpace(Model.Data.Address) ? "N/A" : Model.Data.Address)
                </dd>

                <dt class="col-sm-3 text-muted">Department</dt>
                <dd class="col-sm-9">
                    @if (Model.Data.Departments != null && Model.Data.Departments.Any())
                    {
                        <span class="badge bg-info text-dark">
                            @Model.Data.Departments.First().Text
                        </span>
                    }
                    else
                    {
                        <span class="text-muted fst-italic">No Department</span>
                    }
                </dd>

                <dt class="col-sm-3 text-muted">Roles</dt>
                <dd class="col-sm-9">
                    @if (Model.Data.Roles != null && Model.Data.Roles.Any())
                    {
                        foreach (var role in Model.Data.Roles)
                        {
                            <span class="badge bg-primary me-1">@role.Name</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted fst-italic">No Roles Assigned</span>
                    }
                </dd>
            </dl>

        </div>

        <div class="card-footer d-flex justify-content-between align-items-center">
            <form asp-action="DeleteUser" method="post">
                <input type="hidden" asp-for="@Model.Data.Id" />
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
            </form>
            <a asp-action="Details" asp-route-id="@Model.Data.Id" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i> Cancel
            </a>
        </div>

    </div>

</div>