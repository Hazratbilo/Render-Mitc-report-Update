@model MITCRMS.Models.DTOs.Users.LoginRequestModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | Masroor International Technical College</title>
    <link rel="icon" type="image/png" href="~/Mitc_Logo-removebg-preview.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --login-primary: #204098;
            --login-primary-dark: #00164e;
            --login-primary-soft: #dce1ff;
            --login-surface: #ffffff;
            --login-surface-low: #f4f2fc;
            --login-border: #c4c5d4;
            --login-text: #1a1b22;
            --login-text-muted: #556070;
            --login-text-soft: #747683;
            --login-success-bg: #e7f7ee;
            --login-success-text: #0d6b39;
            --login-danger-bg: #ffded7;
            --login-danger-text: #a32d1a;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
            color: var(--login-text);
            background:
                radial-gradient(circle at top left, rgba(220, 225, 255, 0.82), transparent 22%),
                radial-gradient(circle at bottom right, rgba(188, 199, 222, 0.35), transparent 20%),
                linear-gradient(180deg, #f8fbff 0%, #eef3fb 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 28px 20px;
            position: relative;
            overflow-x: hidden;
        }

        .login-shell {
            width: 100%;
            max-width: 460px;
            position: relative;
            z-index: 2;
        }

        .login-branding {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 10px;
            margin-bottom: 28px;
        }

        .login-branding-mark {
            width: 88px;
            height: 88px;
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, rgba(37, 68, 156, 0.14), rgba(220, 225, 255, 0.95));
            box-shadow: inset 0 0 0 1px rgba(196, 197, 212, 0.65);
            overflow: hidden;
            padding: 12px;
        }

        .login-branding-mark img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .login-branding h1 {
            margin: 0;
            color: var(--login-primary);
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .login-branding p {
            margin: 0;
            max-width: 320px;
            color: var(--login-text-muted);
            font-size: 0.98rem;
            line-height: 1.6;
        }

        .login-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(196, 197, 212, 0.72);
            border-radius: 28px;
            box-shadow: 0 28px 60px rgba(24, 33, 74, 0.12);
            overflow: hidden;
        }

        .login-card-header {
            padding: 28px 28px 18px;
        }

        .login-card-header h2 {
            margin: 0 0 6px;
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--login-text);
        }

        .login-card-header p {
            margin: 0;
            color: var(--login-text-soft);
            font-size: 0.84rem;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        .login-card-body {
            padding: 0 28px 28px;
        }

        .alert {
            display: flex;
            align-items: center;
            gap: 10px;
            border: 0;
            border-radius: 16px;
            padding: 14px 16px;
            margin-bottom: 18px;
        }

        .alert-danger {
            background: var(--login-danger-bg);
            color: var(--login-danger-text);
        }

        .alert-success {
            background: var(--login-success-bg);
            color: var(--login-success-text);
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            padding-left: 4px;
            color: var(--login-text-muted);
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .input-shell {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--login-text-soft);
            font-size: 20px;
        }

        .form-control {
            width: 100%;
            min-height: 54px;
            padding: 14px 16px 14px 48px;
            border-radius: 16px;
            border: 1px solid rgba(196, 197, 212, 0.88);
            background: rgba(244, 242, 252, 0.62);
            color: var(--login-text);
            font-size: 0.96rem;
            transition: all 0.18s ease;
        }

        .form-control:focus {
            border-color: rgba(60, 89, 177, 0.52);
            background: #ffffff;
            box-shadow: 0 0 0 4px rgba(60, 89, 177, 0.08);
        }

        .password-toggle {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            width: 38px;
            height: 38px;
            border: 0;
            border-radius: 12px;
            background: transparent;
            color: var(--login-text-soft);
        }

        .password-toggle:hover {
            color: var(--login-primary);
            background: rgba(220, 225, 255, 0.72);
        }

        .text-danger {
            display: block;
            margin-top: 6px;
            padding-left: 4px;
            font-size: 0.8rem;
        }

        .btn-login {
            width: 100%;
            min-height: 54px;
            margin-top: 8px;
            border: 0;
            border-radius: 16px;
            background: linear-gradient(135deg, var(--login-primary) 0%, #3c59b1 100%);
            color: #ffffff;
            font-size: 1rem;
            font-weight: 700;
            box-shadow: 0 14px 24px rgba(37, 68, 156, 0.24);
            transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
        }

        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 28px rgba(37, 68, 156, 0.28);
        }

        .btn-login:disabled {
            opacity: 0.72;
            transform: none;
            box-shadow: none;
        }

        .login-divider {
            display: flex;
            align-items: center;
            gap: 14px;
            margin: 22px 0 18px;
            color: var(--login-text-soft);
            font-size: 0.76rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .login-divider::before,
        .login-divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: rgba(196, 197, 212, 0.9);
        }

        .login-support {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 22px;
        }

        .login-support a {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--login-text-muted);
            font-size: 0.82rem;
            font-weight: 600;
            text-decoration: none;
        }

        .login-support a:hover {
            color: var(--login-primary);
        }

        .login-footer {
            margin-top: 24px;
            text-align: center;
            color: var(--login-text-soft);
            font-size: 0.78rem;
            line-height: 1.7;
        }

        .spinner {
            display: inline-block;
            width: 16px;
            height: 16px;
            margin-right: 8px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: #ffffff;
            animation: spin 0.6s linear infinite;
            vertical-align: middle;
        }

        .login-wave {
            position: fixed;
            left: 0;
            bottom: 0;
            width: 100%;
            pointer-events: none;
            opacity: 0.22;
            z-index: 1;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        @@media (max-width: 576px) {
            .login-card-header,
            .login-card-body {
                padding-left: 20px;
                padding-right: 20px;
            }

            .login-support {
                flex-direction: column;
                gap: 12px;
            }
        }
    </style>
</head>
<body>
    <main class="login-shell">
        <div class="login-branding">
            <div class="login-branding-mark">
                <img src="~/Mitc_Logo-removebg-preview.png" alt="Masroor ITC Logo" />
            </div>
            <h1>Masroor International Technical College</h1>
            <p>Academic Reporting System for staff reporting, departmental review, and administrative oversight.</p>
        </div>

        <div class="login-card">
            <div class="login-card-header">
                <h2>Sign In</h2>
                @* <p>Secure Staff Access Portal</p> *@
            </div>

            <div class="login-card-body">
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger" role="alert">
                        <span class="material-symbols-outlined">error</span>
                        <span>@ViewBag.ErrorMessage</span>
                    </div>
                }

                @if (ViewBag.SuccessMessage != null)
                {
                    <div class="alert alert-success" role="alert">
                        <span class="material-symbols-outlined">check_circle</span>
                        <span>@ViewBag.SuccessMessage</span>
                    </div>
                }

                <form asp-action="Login" method="post" id="loginForm">
                    <div class="form-group">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <div class="input-shell">
                            <span class="material-symbols-outlined input-icon">mail</span>
                            <input asp-for="Email"
                                   class="form-control"
                                   type="email"
                                   placeholder="name@college.edu"
                                   autocomplete="username" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Password" class="form-label">Password</label>
                        <div class="input-shell">
                            <span class="material-symbols-outlined input-icon">lock</span>
                            <input asp-for="Password"
                                   class="form-control"
                                   type="password"
                                   id="passwordInput"
                                   placeholder="Enter your password"
                                   autocomplete="current-password" />
                            <button type="button" class="password-toggle" id="togglePassword" aria-label="Toggle password visibility">
                                <span class="material-symbols-outlined">visibility</span>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-login" id="loginButton">
                        <span id="buttonText">Sign In</span>
                    </button>
                </form>

                <div class="login-divider">Secure Access</div>

               @*  <div class="login-support">
                    <a href="#">
                        <span class="material-symbols-outlined" style="font-size:16px;">contact_support</span>
                        <span>Support</span>
                    </a>
                    <a href="#">
                        <span class="material-symbols-outlined" style="font-size:16px;">verified_user</span>
                        <span>Policy</span>
                    </a>
                </div> *@
            </div>
        </div>

        <div class="login-footer">
            <p>&copy; @DateTime.Now.Year Masroor International Technical College. All rights reserved.</p>
            <p>Authorized personnel only. System monitoring is active.</p>
        </div>
    </main>

    <div class="login-wave">
        <svg viewBox="0 0 1440 320" xmlns="http://www.w3.org/2000/svg">
            <path fill="#bcc7de" d="M0 256L48 229.3C96 203 192 149 288 154.7C384 160 480 224 576 218.7C672 213 768 139 864 128C960 117 1056 171 1152 197.3C1248 224 1344 224 1392 224L1440 224V320H1392C1344 320 1248 320 1152 320C1056 320 960 320 864 320C768 320 672 320 576 320C480 320 384 320 288 320C192 320 96 320 48 320H0V256Z"></path>
        </svg>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        const togglePassword = document.getElementById('togglePassword');
        const passwordInput = document.getElementById('passwordInput');

        togglePassword.addEventListener('click', function () {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            this.innerHTML = type === 'password'
                ? '<span class="material-symbols-outlined">visibility</span>'
                : '<span class="material-symbols-outlined">visibility_off</span>';
        });

        const loginForm = document.getElementById('loginForm');
        const loginButton = document.getElementById('loginButton');
        const buttonText = document.getElementById('buttonText');

        loginForm.addEventListener('submit', function () {
            loginButton.disabled = true;
            buttonText.innerHTML = '<span class="spinner"></span>Signing in...';
        });

        setTimeout(function () {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(function (alert) {
                alert.style.transition = 'opacity 0.5s ease';
                alert.style.opacity = '0';
                setTimeout(function () {
                    alert.remove();
                }, 500);
            });
        }, 5000);
    </script>
</body>
</html>
