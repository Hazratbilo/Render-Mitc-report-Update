@using MITCRMS.Models.DTOs.Report
@using MITCRMS.Models.Enum
@model IEnumerable<ReportDto>

@{
    Layout = "_StaffLayout";
    ViewData["Title"] = "Dashboard";

    var reports = (Model ?? Enumerable.Empty<ReportDto>())
        .OrderByDescending(r => r.DateCreated)
        .ToList();

    var totalReports = reports.Count;
    var pendingReports = reports.Count(r => r.Status == ReportStatus.Pending);
    var approvedReports = reports.Count(r => r.Status == ReportStatus.Approved);
    var rejectedReports = reports.Count(r => r.Status == ReportStatus.Rejected);
    var recentReports = reports.Take(5).ToList();
    var approvalRate = totalReports > 0 ? Math.Round((double)approvedReports / totalReports * 100) : 0;
    var monthTrend = totalReports > 0 ? $"+{Math.Min(totalReports, 12)} active submissions" : "Start your first submission";
}

<section class="staff-page-header">
    <div>
        <span class="staff-page-eyebrow">
            <span class="material-symbols-outlined">school</span>
            Staff Workspace
        </span>
        <h1 class="staff-page-title">Welcome back, @User.Identity?.Name</h1>
        <p class="staff-page-subtitle">
            Here is a polished overview of your reporting activity, recent submissions, and approval progress for the current session.
        </p>
    </div>
</section>

<section class="staff-dashboard-grid">
    <a asp-controller="Report" asp-action="GetMyReports" class="staff-stat-card staff-stat-card-total">
        <div class="staff-stat-card-top">
            <span class="staff-stat-icon">
                <span class="material-symbols-outlined">assignment</span>
            </span>
            <span class="staff-stat-trend">@monthTrend</span>
        </div>
        <p class="staff-stat-label">Total Reports Submitted</p>
        <h2 class="staff-stat-value">@totalReports</h2>
    </a>

    <a asp-controller="Report" asp-action="GetMyReports" asp-route-status="@ReportStatus.Pending" class="staff-stat-card staff-stat-card-pending">
        <div class="staff-stat-card-top">
            <span class="staff-stat-icon">
                <span class="material-symbols-outlined">pending_actions</span>
            </span>
        </div>
        <p class="staff-stat-label">Pending Approval</p>
        <h2 class="staff-stat-value">@pendingReports</h2>
    </a>

    <a asp-controller="Report" asp-action="GetMyReports" asp-route-status="@ReportStatus.Approved" class="staff-stat-card staff-stat-card-approved">
        <div class="staff-stat-card-top">
            <span class="staff-stat-icon">
                <span class="material-symbols-outlined">verified</span>
            </span>
            <span class="staff-stat-trend">@approvalRate% approval rate</span>
        </div>
        <p class="staff-stat-label">Approved Reports</p>
        <h2 class="staff-stat-value">@approvedReports</h2>
    </a>
</section>

<section class="staff-dashboard-panels">
    <div class="staff-panel">
        <div class="staff-panel-header">
            <div>
                <h2 class="staff-panel-title">Recent Reports</h2>
            </div>
            <a asp-controller="Report" asp-action="GetMyReports" class="staff-panel-link">View All History</a>
        </div>

        @if (recentReports.Any())
        {
            <div class="staff-table-wrap">
                <table class="staff-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Title</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in recentReports)
                        {
                            var statusClass = report.Status switch
                            {
                                ReportStatus.Approved => "staff-status-approved",
                                ReportStatus.Rejected => "staff-status-rejected",
                                _ => "staff-status-pending"
                            };
                            <tr>
                                <td>@report.DateCreated.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="staff-table-title">@report.Tittle</span>
                                    <span class="staff-table-subtext">Submitted @report.DateCreated.ToString("hh:mm tt")</span>
                                </td>
                                <td>
                                    <span class="staff-status-badge @statusClass">@report.Status</span>
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Report" asp-action="Details" asp-route-id="@report.Id" class="staff-table-action" title="View report">
                                        <span class="material-symbols-outlined">visibility</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="staff-empty-state">
                <span class="material-symbols-outlined">inbox</span>
                <h3>No reports yet</h3>
                <p>Your recent reporting activity will appear here once you submit your first report.</p>
            </div>
        }
    </div>

    <div class="staff-side-stack">
        <div class="staff-highlight-panel staff-cta-panel">
            <h2 class="staff-panel-title">Quick Actions</h2>
            <p class="staff-cta-panel-copy">
                Ready to document your latest academic activity, session outcome, or departmental update?
            </p>

            <a asp-controller="Report" asp-action="CreateReport" class="staff-cta-button">
                <span class="material-symbols-outlined">post_add</span>
                <span>Submit New Report</span>
            </a>

            <div class="staff-mini-actions">
                <a asp-controller="Report" asp-action="GetMyReports" class="staff-mini-action">
                    <span class="material-symbols-outlined">draft</span>
                    <span>View Reports</span>
                </a>
                <a asp-controller="Report" asp-action="GetMyReports" asp-route-status="@ReportStatus.Pending" class="staff-mini-action">
                    <span class="material-symbols-outlined">help_center</span>
                    <span>Pending Queue</span>
                </a>
            </div>
        </div>

        <div class="staff-highlight-panel">
            <span class="staff-announcement-tag">Announcement</span>
            <h2 class="staff-panel-title mt-3">Reporting quality matters</h2>
            <p class="staff-announcement-copy">
                Clear titles, structured summaries, and complete attachments help reviewers process submissions faster and improve approval turnaround.
            </p>
            <a asp-controller="Report" asp-action="CreateReport" class="staff-panel-link">Open report form</a>
        </div>

        <div class="staff-highlight-panel">
            <h2 class="staff-panel-title">Submission Snapshot</h2>
            <p class="staff-announcement-copy mb-3">
                Keep an eye on your current report pipeline.
            </p>
            <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                <span class="text-muted">Approved</span>
                <strong class="text-success">@approvedReports</strong>
            </div>
            <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                <span class="text-muted">Pending</span>
                <strong style="color:#8a6300;">@pendingReports</strong>
            </div>
            <div class="d-flex justify-content-between align-items-center py-2">
                <span class="text-muted">Rejected</span>
                <strong class="text-danger">@rejectedReports</strong>
            </div>
        </div>
    </div>
</section>
