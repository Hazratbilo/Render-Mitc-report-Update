@using MITCRMS.Models.DTOs.Users
@using MITCRMS.Models.Entities
@model UserDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Staff Details";
}

<div class="container-fluid px-4 py-3">
    <div class="admin-page-header">
        <div>
            <div class="dept-create-breadcrumb text-muted small mb-1">Staff Directory / Details</div>
            <h1 class="admin-page-title">Staff Profile Details</h1>
            <p class="admin-page-subtitle">View personal information, assigned departments, roles, and status details.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="DeleteUser" asp-route-id="@Model.Id" class="btn btn-outline-danger d-inline-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">delete</span>
                <span>Delete Staff</span>
            </a>
            <a asp-action="GetAllUsersWithRoles" class="btn btn-outline-secondary d-inline-flex align-items-center gap-2">
                <span class="material-symbols-outlined fs-5">arrow_back</span>
                <span>Back to Directory</span>
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <span class="material-symbols-outlined align-middle me-2">check_circle</span>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <span class="material-symbols-outlined align-middle me-2">error</span>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4 mt-1">
        <div class="col-xl-8 col-lg-7">
            <div class="admin-panel mb-4">
                <div class="admin-panel-header py-3 px-4 border-bottom bg-light bg-opacity-50">
                    <div class="d-flex align-items-center gap-3">
                        <div class="admin-avatar text-white bg-primary d-inline-flex align-items-center justify-content-center fw-bold fs-4" style="width: 58px; height: 58px; border-radius: 16px; background: linear-gradient(135deg, var(--admin-primary), #627fd4);">
                            @((Model.FullName ?? "U").Substring(0, 1).ToUpper())
                        </div>
                        <div>
                            <h4 class="admin-panel-title mb-1 text-dark">@Model.FullName</h4>
                            <p class="text-muted small mb-0">Registered staff member account</p>
                        </div>
                    </div>
                </div>

                <div class="p-4">
                    <div class="row g-4">
                        <div class="col-12">
                            <h5 class="fw-bold text-primary mb-3 pb-2 border-bottom d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined">person</span>
                                <span>Personal Information</span>
                            </h5>
                        </div>

                        <div class="col-md-6">
                            <div>
                                <span class="d-block text-muted small text-uppercase fw-semibold mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">First Name</span>
                                <span class="fs-6 text-dark fw-medium">@Model.FirstName</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div>
                                <span class="d-block text-muted small text-uppercase fw-semibold mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Last Name</span>
                                <span class="fs-6 text-dark fw-medium">@Model.LastName</span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div>
                                <span class="d-block text-muted small text-uppercase fw-semibold mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Email Address</span>
                                <span class="fs-6 text-dark fw-medium">
                                    <a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a>
                                </span>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div>
                                <span class="d-block text-muted small text-uppercase fw-semibold mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Phone Number</span>
                                <span class="fs-6 text-dark fw-medium">
                                    <a href="tel:@Model.PhoneNumber" class="text-decoration-none">@Model.PhoneNumber</a>
                                </span>
                            </div>
                        </div>

                        <div class="col-12">
                            <div>
                                <span class="d-block text-muted small text-uppercase fw-semibold mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Residence Address</span>
                                <span class="fs-6 text-dark">@(string.IsNullOrWhiteSpace(Model.Address) ? "N/A" : Model.Address)</span>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <h5 class="fw-bold text-primary mb-3 pb-2 border-bottom d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined">domain</span>
                                <span>Department & Roles</span>
                            </h5>
                        </div>

                        <div class="col-md-6">
                            <div>
                                <span class="d-block text-muted small text-uppercase fw-semibold mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">Department</span>
                                <div>
                                    @if (Model.Departments != null && Model.Departments.Any())
                                    {
                                        <span class="badge bg-light text-dark border fs-6 px-3 py-2">
                                            @Model.Departments.First().Text
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">No Department Assigned</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div>
                                <span class="d-block text-muted small text-uppercase fw-semibold mb-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">System Roles</span>
                                <div>
                                    @if (Model.Roles != null && Model.Roles.Any())
                                    {
                                        foreach (var role in Model.Roles)
                                        {
                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 fs-6 px-3 py-2 me-1">@role.Name</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">No Roles Assigned</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light bg-opacity-50 py-3 px-4 border-top d-flex justify-content-between align-items-center">
                    <span class="text-muted small d-inline-flex align-items-center gap-1">
                        <span class="material-symbols-outlined fs-5">schedule</span>
                        <span>Account Created: @Model.DateCreated.ToString("g")</span>
                    </span>
                    <span class="text-muted small">User ID: @Model.Id</span>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-5">
            <div class="admin-panel p-4 bg-white border border-light-subtle rounded-4 mb-4">
                <h5 class="text-dark fw-bold d-flex align-items-center gap-2 mb-3">
                    <span class="material-symbols-outlined text-primary">security</span>
                    <span>Access & Activity</span>
                </h5>
                <p class="text-muted small mb-3">
                    This account is currently active. The user is authorized to log in using their registered email and submit departmental academic reports.
                </p>
                <div class="p-3 bg-light rounded-3">
                    <span class="d-block text-muted small text-uppercase fw-semibold mb-1" style="font-size: 0.7rem; letter-spacing: 0.05em;">Login Access</span>
                    <span class="text-success fw-bold d-inline-flex align-items-center gap-1 small">
                        <span class="material-symbols-outlined fs-5">check_circle</span>
                        <span>Authorized Access</span>
                    </span>
                </div>
            </div>

            <div class="admin-panel p-4 bg-white border border-light-subtle rounded-4">
                <h5 class="text-dark fw-bold d-flex align-items-center gap-2 mb-3">
                    <span class="material-symbols-outlined text-primary">assignment_ind</span>
                    <span>Role Permissions</span>
                </h5>
                <p class="text-muted small mb-0">
                    Role assignments dictate access boundaries. Admin and HOD roles are granted viewing and approving permissions across department reports, while standard staff accounts are limited to report generation.
                </p>
            </div>
        </div>
    </div>
</div>