@using MITCRMS.Models.DTOs.Users
@using MITCRMS.Models.Entities
@model UserDto

@{
    ViewData["Title"] = "Staff Details";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Staff Details</h2>

        <div>
            <a asp-action="DeleteUser" asp-route-id="@Model.Id" class="btn btn-danger me-2">
                <i class="bi bi-trash"></i> Delete
            </a>
            <a asp-action="GetAllUsersWithRoles" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-person-circle me-2"></i>@Model.FullName
            </h5>
        </div>

        <div class="card-body">
            <div class="row g-4">

                     <div class="col-md-6">
                    <div class="card h-100 border-0 bg-light">
                        <div class="card-body">
                            <h6 class="card-title text-muted fw-semibold mb-3">
                                <i class="bi bi-person me-1"></i> Personal Information
                            </h6>

                            <dl class="row mb-0">
                                <dt class="col-sm-4 text-muted">First Name</dt>
                                <dd class="col-sm-8">@Model.FirstName</dd>

                                <dt class="col-sm-4 text-muted">Last Name</dt>
                                <dd class="col-sm-8">@Model.LastName</dd>

                                <dt class="col-sm-4 text-muted">Email</dt>
                                <dd class="col-sm-8">
                                    <a href="mailto:@Model.Email">@Model.Email</a>
                                </dd>

                                <dt class="col-sm-4 text-muted">Phone</dt>
                                <dd class="col-sm-8">
                                    <a href="tel:@Model.PhoneNumber">@Model.PhoneNumber</a>
                                </dd>

                                <dt class="col-sm-4 text-muted">Address</dt>
                                <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Address) ? "N/A" : Model.Address)</dd>
                            </dl>
                        </div>
                    </div>
                </div>

             
                <div class="col-md-6">
                    <div class="card h-100 border-0 bg-light">
                        <div class="card-body">
                            <h6 class="card-title text-muted fw-semibold mb-3">
                                <i class="bi bi-building me-1"></i> Department & Roles
                            </h6>

                            <dl class="row mb-0">
                                <dt class="col-sm-4 text-muted">Department</dt>
                                <dd class="col-sm-8">
                                    @if (Model.Departments != null && Model.Departments.Any())
                                    {
                                        <span class="badge bg-info text-dark">
                                            @Model.Departments.First().Text
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">No Department</span>
                                    }
                                </dd>

                                <dt class="col-sm-4 text-muted">Roles</dt>
                                <dd class="col-sm-8">
                                    @if (Model.Roles != null && Model.Roles.Any())
                                    {
                                        foreach (var role in Model.Roles)
                                        {
                                            <span class="badge bg-primary me-1">@role.Name</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">No Roles Assigned</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        <div>
           <div class="card-footer text-muted small">
                Created: @Model.DateCreated.ToString("g")
        </div>

        <div class="card-footer text-muted small">
            User ID: @Model.Id
        </div>
    </div>

</div>